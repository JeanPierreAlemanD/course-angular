pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'qa', 'prod'], description: 'Ambiente')
    }

    stages {

        stage('Build Docker Image') {
            steps {
                sh """
                docker build -t myapp:${params.ENVIRONMENT} .
                """
            }
        }

        stage('Deploy') {
            steps {
                sh """
                docker stop myapp-${params.ENVIRONMENT} || true
                docker rm myapp-${params.ENVIRONMENT} || true

                if [ "${params.ENVIRONMENT}" = "dev" ]; then
                  PORT=4200
                elif [ "${params.ENVIRONMENT}" = "qa" ]; then
                  PORT=4300
                else
                  PORT=80
                fi

                docker run -d \
                  -p $PORT:80 \
                  --name myapp-${params.ENVIRONMENT} \
                  myapp:${params.ENVIRONMENT}
                """
            }
        }
    }
}