pipeline {
    agent {
        docker {
            image 'node:20'
            args '-u root:root'
        }
    }

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'qa', 'prod'], description: 'Selecciona el ambiente')
    }

    stages {

        stage('Install') {
            steps {
                sh 'npm install'
            }
        }

        stage('Build') {
            steps {
                sh "npm run build -- --configuration=${params.ENVIRONMENT}"
            }
        }

        stage('Deploy') {
            steps {
                sh "echo Desplegando a ${params.ENVIRONMENT}"
            }
        }
    }
}